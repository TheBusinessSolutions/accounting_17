<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="view_expense_statement_form" model="ir.ui.view">
        <field name="name">expense.statement.form</field>
        <field name="model">expense.statement</field>
        <field name="arch" type="xml">
            <form string="Expense Statement">

                <header>
                    <button name="action_validate"
                            string="Validate"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>

                    <button name="action_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state != 'posted'"/>

                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>

                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="journal_id"
                                   domain="[('type', 'in', ['bank', 'cash'])]"
                                   readonly="state == 'posted'"/>

                            <field name="date"
                                   readonly="state == 'posted'"/>
                        </group>

                        <group>
                            <field name="description"
                                   readonly="state == 'posted'"/>

                            <field name="move_id"
                                   invisible="not move_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Transactions">

                            <field name="line_ids"
                                   readonly="state == 'posted'">

                                <tree editable="bottom">
                                    <field name="transaction_type"/>
                                    <field name="account_id"/>
                                    <field name="note"/>
                                    <field name="amount"/>
                                </tree>

                            </field>

                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- TREE VIEW -->
    <record id="view_expense_statement_tree" model="ir.ui.view">
        <field name="name">expense.statement.tree</field>
        <field name="model">expense.statement</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="journal_id"/>
                <field name="state"
                       widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'posted'"/>
            </tree>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_expense_statement" model="ir.actions.act_window">
        <field name="name">Expense Statements</field>
        <field name="res_model">expense.statement</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <!-- MENU -->
    <menuitem id="menu_expense_statement"
              name="Expense Statements"
              parent="account.menu_finance"
              action="action_expense_statement"
              sequence="35"/>

</odoo>