<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_partner_balance" model="ir.ui.view">
        <field name="name">account.move.form.inherit.partner.balance</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Add refresh button to header -->
            <xpath expr="//header" position="inside">
                <button name="action_refresh_balances" 
                        string="Refresh Balance" 
                        type="object" 
                        class="btn-secondary" 
                        groups="account.group_account_invoice" 
                        invisible="state not in ('draft', 'posted')"/>
            </xpath>

            <!-- Add balance fields to Other Info tab -->
            <xpath expr="//page[@name='other_info']" position="inside">
                <group string="Customer/Supplier Balance" name="partner_balance_group" groups="account.group_account_invoice">
                    <field name="partner_balance_before" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                    <field name="partner_balance_after" widget="monetary" options="{'currency_field': 'company_currency_id'}"/>
                    <button string="🔄 Refresh Balance" name="action_refresh_balances" type="object" class="btn-link text-primary" groups="account.group_account_invoice"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>